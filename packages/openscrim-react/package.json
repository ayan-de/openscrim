{
  "name": "@thisisayande/openscrim-react",
  "version": "0.2.0",
  "description": "React SDK for OpenScrim — drop-in <ScrimRecorder> / <ScrimPlayer> components and headless hooks to record and replay interactive, forkable code screencasts. Bring your own storage.",
  "keywords": [
    "react",
    "monaco",
    "monaco-editor",
    "scrimba",
    "screencast",
    "code-recording",
    "playback",
    "interactive-tutorial",
    "scrim",
    "sdk"
  ],
  "license": "MIT",
  "author": "Ayan De",
  "homepage": "https://github.com/ayan-de/openscrim#readme",
  "bugs": "https://github.com/ayan-de/openscrim/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayan-de/openscrim.git",
    "directory": "packages/openscrim-react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "echo 'No lint configured'",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@thisisayande/openscrim-core": "workspace:*",
    "@thisisayande/openscrim-monaco": "workspace:*"
  },
  "peerDependencies": {
    "@monaco-editor/react": ">=4.6.0",
    "monaco-editor": ">=0.30.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "monaco-editor": "^0.53.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
