{
  "name": "@thisisayande/openscrim-player",
  "version": "0.1.1",
  "description": "Drop-in player for OpenScrim interactive code screencasts — one script tag or one function call, no Monaco setup required",
  "keywords": [
    "scrimba",
    "screencast",
    "code-recording",
    "playback",
    "embed",
    "player",
    "interactive-tutorial",
    "scrim"
  ],
  "license": "MIT",
  "author": "Ayan De",
  "homepage": "https://github.com/ayan-de/openscrim#readme",
  "bugs": "https://github.com/ayan-de/openscrim/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayan-de/openscrim.git",
    "directory": "packages/openscrim-player"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/embed.global.js",
  "jsdelivr": "./dist/embed.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./embed": "./dist/embed.global.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "echo 'No lint configured'",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.4.0",
    "@thisisayande/openscrim-core": "workspace:*",
    "@thisisayande/openscrim-monaco": "workspace:*"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "monaco-editor": "^0.53.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
