{
  "name": "@thisisayande/openscrim-monaco",
  "version": "0.1.1",
  "description": "Monaco editor binding for OpenScrim — record and replay interactive, forkable code screencasts in any Monaco host",
  "keywords": [
    "monaco",
    "monaco-editor",
    "scrimba",
    "screencast",
    "code-recording",
    "playback",
    "interactive-tutorial",
    "scrim"
  ],
  "license": "MIT",
  "author": "Ayan De",
  "homepage": "https://github.com/ayan-de/openscrim#readme",
  "bugs": "https://github.com/ayan-de/openscrim/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayan-de/openscrim.git",
    "directory": "packages/openscrim-monaco"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "echo 'No lint configured'",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@thisisayande/openscrim-core": "workspace:*"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.30.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "monaco-editor": "^0.53.0",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
