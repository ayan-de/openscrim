{
  "name": "@thisisayande/openscrim-core",
  "version": "0.2.0",
  "description": "Framework-agnostic engine for recording and replaying code editor sessions as timestamped events — an open-source Scrimba-style scrim format",
  "keywords": [
    "scrimba",
    "screencast",
    "code-recording",
    "playback",
    "interactive-tutorial",
    "coding-education",
    "scrim"
  ],
  "license": "MIT",
  "author": "Ayan De",
  "homepage": "https://github.com/ayan-de/openscrim#readme",
  "bugs": "https://github.com/ayan-de/openscrim/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayan-de/openscrim.git",
    "directory": "packages/openscrim-core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "echo 'No lint configured'",
    "test": "vitest run",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
